# ---------------------------------------------------------------------------
# Production environment template — Hostinger Single (shared, no SSH), MariaDB.
#
# Create the real .env ONCE on the server via hPanel → File Manager by copying
# this file to `.env` and filling in the blanks, then set APP_KEY.
#   - APP_KEY: run `php -r "echo 'base64:'.base64_encode(random_bytes(32));"`
#     locally and paste the result, since there's no SSH to run key:generate.
# This file is a committed template (no secrets). The real .env is NOT committed
# to any branch and must survive redeploys — back it up before the first one.
# See DEPLOY.md for the full step-by-step.
# ---------------------------------------------------------------------------

APP_NAME=Lapak
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://your-domain.example

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Quieter logs in production; daily rotation keeps disk usage bounded.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database: MariaDB (Hostinger) --------------------------------------
# Hostinger serves MariaDB; the `mysql` driver is the broadly-compatible choice
# and is what hPanel's tutorials assume. Verified against MariaDB 10.4 (full
# migrate + seed + test suite green). Create the database and user in
# hPanel → Databases → Management; both names are usually prefixed (e.g.
# "u123456789_lapak").
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Sessions/cache use database tables (no Redis on this plan) — created by
# `php artisan migrate`.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Lock cookies to your domain and require HTTPS in production:
SESSION_DOMAIN=your-domain.example
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# This app dispatches no background jobs, so "sync" needs no queue worker.
QUEUE_CONNECTION=sync

CACHE_STORE=database
CACHE_PREFIX=

# --- Deploy migration hook ----------------------------------------------
# Authorizes GET /deploy/migrate, which runs pending migrations on a host with
# no SSH. Leave BLANK to disable the route entirely (it 404s). Only set this if
# you can't run the artisan command via an hPanel Cron Job. Use a long random
# value:  php -r "echo bin2hex(random_bytes(24)).PHP_EOL;"
DEPLOY_MIGRATE_TOKEN=

# --- Mail ---------------------------------------------------------------
# Password-reset emails need real SMTP. Leave as "log" to disable outbound mail
# (reset links are written to the log instead).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@your-domain.example"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
